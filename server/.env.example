# Server
PORT=3000

# CORS（生产环境在 Vercel Dashboard 配置）
ALLOWED_ORIGINS=

# Database (MySQL) — 若仍使用 MySQL 业务层
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=resume_screening
DATABASE_URL=mysql://root:password@localhost:3306/resume_screening

# Turso / libsql（Drizzle：src/db/index.ts）
# 在 https://turso.tech 创建数据库后，复制 Connection URL 与「Create Token」生成的 JWT
TURSO_DATABASE_URL=libsql://your-db-name-xxxxx.aws-region.turso.io
TURSO_AUTH_TOKEN=

# JWT（应用登录，与 Turso Token 无关）
JWT_SECRET=
JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d

ENCRYPTION_KEY=

# =============================================================================
# ⚠️ 部署到 Vercel 时，请务必在 Vercel Dashboard 中配置以下环境变量：
#   https://vercel.com/YOUR_PROJECT/settings/environment-variables
#
# 在 Vercel 添加以下 4 个变量（Build & Runtime 均可访问）：
#   1. TURSO_DATABASE_URL    ← 值为上方 .env 中相同的 URL
#   2. TURSO_AUTH_TOKEN      ← 值为上方 .env 中相同的 Token
#   3. JWT_SECRET           ← 设为任意随机字符串（如：openssl rand -hex 32）
#   4. ENCRYPTION_KEY       ← 设为任意随机字符串（用于加密邮箱授权码）
#
# ⚠️ 不要将 .env 文件部署到 Vercel，Vercel Dashboard 是管理生产环境变量的正确方式。
# =============================================================================
